      <description>&lt;p&gt;slug: Pico&lt;/p&gt;&#xA;&lt;h1 id=&#34;raspberry-pico&#34;&gt;Raspberry Pico&lt;a href=&#34;#raspberry-pico&#34; class=&#34;heading-anchor&#34; aria-label=&#34;連結到此部分&#34;&gt;&lt;svg class=&#34;h-4 w-4&#34; aria-hidden=&#34;true&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34; viewBox=&#34;0 0 24 24&#34;&gt;&lt;g fill=&#34;none&#34; stroke=&#34;currentColor&#34; stroke-linecap=&#34;round&#34; stroke-linejoin=&#34;round&#34; stroke-width=&#34;2&#34;&gt;&lt;path d=&#34;M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71&#34;/&gt;&lt;path d=&#34;M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71&#34;/&gt;&lt;/g&gt;&lt;/svg&gt;&lt;/a&gt;&lt;/h1&gt;&lt;ol&gt;&#xA;&lt;li&gt;使用 Thonny 將 blink (內建LED燈閃爍) 程式燒錄到 Pico&lt;/li&gt;&#xA;&lt;li&gt;使用 Pico + 1602 LCD 顯示內建溫度感測器讀取到的溫度資料&lt;/li&gt;&#xA;&lt;li&gt;使用 Raspberry Pi 燒錄/除錯 Pico 程式(All)&#xA;&#xA;&lt;figure&#xA;  class=&#34;image-figure not-prose my-8&#34;&#xA;  data-lightbox-enabled=&#34;&#xA;    true&#xA;  &#34;&#xA;  data-gallery-type=&#34;auto&#34;&#xA;  data-image-width=&#34;0&#34;&#xA;  data-image-height=&#34;0&#34;&#xA;  data-image-src=&#34;https://i.imgur.com/C09WwSI.jpg&#34;&#xA;&gt;&#xA;  &lt;div class=&#34;image-container&#34;&gt;&#xA;    &lt;img&#xA;    src=&#34;https://i.imgur.com/C09WwSI.jpg&#34;&#xA;    alt=&#34;&#34;&#xA;    &#xA;    &#xA;    loading=&#34;lazy&#34;&#xA;    decoding=&#34;async&#34;&#xA;    data-gallery-src=&#34;https://i.imgur.com/C09WwSI.jpg&#34;&#xA;    data-gallery-alt=&#34;&#34;&#xA;    data-gallery-title=&#34;&#34;&#xA;  /&gt;&lt;/div&gt;&#xA;&#xA;  &lt;/figure&gt;&#xA;&lt;/li&gt;&#xA;&lt;/ol&gt;&#xA;&lt;ul&gt;&#xA;&lt;li&gt;getTemp.py&lt;/li&gt;&#xA;&lt;li&gt;取溫度程式&lt;/li&gt;&#xA;&lt;/ul&gt;&#xA;&lt;div&#xA;  class=&#34;code-block-container border-border bg-card my-6 overflow-hidden rounded-xl border shadow-sm transition-all duration-200 ease-out hover:-translate-y-0.5 hover:shadow-md&#34;&#xA;  data-code-block&#xA;  data-code-id=&#34;code-0&#34;&#xA;  data-collapsible=&#34;true&#34;&#xA;  data-default-state=&#34;expanded&#34;&#xA;  data-collapsed=&#34;false&#34;&#xA;  data-auto-collapse-lines=&#34;30&#34;&#xA;  data-auto-collapse-height=&#34;400&#34;&#xA;  data-collapsed-height=&#34;120&#34;&#xA;&gt;&#xA;  &#xA;  &lt;div&#xA;    class=&#34;code-block-header bg-muted/30 border-border flex items-center justify-between border-b px-4 py-3&#34;&#xA;  &gt;&#xA;    &#xA;    &lt;div class=&#34;flex items-center gap-2&#34;&gt;&#xA;      &lt;div class=&#34;text-muted-foreground shrink-0&#34;&gt;&#xA;        &lt;svg class=&#34;h-4 w-4&#34; fill=&#34;none&#34; stroke=&#34;currentColor&#34; viewBox=&#34;0 0 24 24&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34;&gt;&#xA;  &lt;path stroke-linecap=&#34;round&#34; stroke-linejoin=&#34;round&#34; stroke-width=&#34;2&#34; d=&#34;M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4&#34; /&gt;&#xA;&lt;/svg&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;span class=&#34;text-muted-foreground text-sm font-medium&#34;&gt;&#xA;        PYTHON=&#xA;      &lt;/span&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &#xA;    &lt;div class=&#34;flex items-center gap-2&#34;&gt;&#xA;      &lt;button&#xA;          class=&#34;collapse-code-btn text-muted-foreground hover:text-primary hover:bg-primary/10 focus:ring-primary/20 flex items-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium transition-all duration-200 ease-out focus:ring-2 focus:outline-none&#34;&#xA;          type=&#34;button&#34;&#xA;          data-code-action=&#34;toggle-collapse&#34;&#xA;          data-label-expand=&#34;展開&#34;&#xA;          data-label-collapse=&#34;摺疊&#34;&#xA;          title=&#34;摺疊&#34;&#xA;          aria-label=&#34;摺疊&#34;&#xA;          aria-controls=&#34;code-0&#34;&#xA;          aria-expanded=&#34;true&#34;&#xA;        &gt;&#xA;          &lt;span class=&#34;collapse-chevron transition-transform duration-200 ease-out&#34;&gt;&#xA;            &lt;svg class=&#34;h-3 w-3&#34; fill=&#34;none&#34; stroke=&#34;currentColor&#34; viewBox=&#34;0 0 24 24&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34;&gt;&#xA;  &lt;path stroke-linecap=&#34;round&#34; stroke-linejoin=&#34;round&#34; stroke-width=&#34;2&#34; d=&#34;M19 9l-7 7-7-7&#34; /&gt;&#xA;&lt;/svg&gt;&#xA;          &lt;/span&gt;&#xA;          &lt;span class=&#34;collapse-text hidden sm:inline&#34;&gt;摺疊&lt;/span&gt;&#xA;        &lt;/button&gt;&#xA;      &lt;button&#xA;        class=&#34;copy-code-btn text-muted-foreground hover:text-primary hover:bg-primary/10 focus:ring-primary/20 flex items-center gap-1.5 rounded-md px-2 py-1 text-xs font-medium transition-all duration-200 ease-out focus:ring-2 focus:outline-none&#34;&#xA;        type=&#34;button&#34;&#xA;        data-code-action=&#34;copy&#34;&#xA;        data-label-copy=&#34;複製&#34;&#xA;        data-label-copied=&#34;已複製&#34;&#xA;        title=&#34;複製&#34;&#xA;        aria-label=&#34;複製&#34;&#xA;      &gt;&#xA;        &lt;span class=&#34;copy-icon&#34;&gt;&#xA;          &lt;svg class=&#34;h-3 w-3&#34; fill=&#34;none&#34; stroke=&#34;currentColor&#34; viewBox=&#34;0 0 24 24&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34;&gt;&#xA;  &lt;path stroke-linecap=&#34;round&#34; stroke-linejoin=&#34;round&#34; stroke-width=&#34;2&#34; d=&#34;M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z&#34; /&gt;&#xA;&lt;/svg&gt;&#xA;        &lt;/span&gt;&#xA;        &lt;span class=&#34;copy-text hidden sm:inline&#34;&gt;複製&lt;/span&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&#xA;  &#xA;  &lt;div class=&#34;code-block-content relative&#34; id=&#34;code-0&#34;&gt;&#xA;    &lt;pre tabindex=&#34;0&#34;&gt;&lt;code class=&#34;language-Python=&#34; data-lang=&#34;Python=&#34;&gt;import utime&#xA;from machine import I2C, Pin, ADC&#xA;from lcd_api import LcdApi&#xA;from pico_i2c_lcd import I2cLcd&#xA;I2C_ADDR     = 63&#xA;I2C_NUM_ROWS = 2&#xA;I2C_NUM_COLS = 16&#xA;&#xA;i2c = I2C(0, sda=Pin(0), scl=Pin(1), freq=400000)&#xA;lcd = I2cLcd(i2c, I2C_ADDR, I2C_NUM_ROWS, I2C_NUM_COLS)&#xA;def read_temp():&#xA;    sensor_temp = ADC(4)&#xA;    conversion_factor = 3.3 / (65535)&#xA;    reading = sensor_temp.read_u16() * conversion_factor &#xA;    temperature = 27 - (reading - 0.706)/0.001721&#xA;    formatted_temperature = &amp;#34;{:.2f}&amp;#34;.format(temperature)&#xA;    string_temperature = str(&amp;#34;Temp:&amp;#34; + formatted_temperature)&#xA;    print(string_temperature)&#xA;    utime.sleep(2)&#xA;    return string_temperature&#xA;while True:&#xA;    temperature = read_temp()&#xA;    lcd.move_to(0,0)&#xA;    lcd.putstr(temperature)&lt;/code&gt;&lt;/pre&gt;&#xA;    &lt;div hidden data-code-source&gt;import utime&#xA;from machine import I2C, Pin, ADC&#xA;from lcd_api import LcdApi&#xA;from pico_i2c_lcd import I2cLcd&#xA;I2C_ADDR     = 63&#xA;I2C_NUM_ROWS = 2&#xA;I2C_NUM_COLS = 16&#xA;&#xA;i2c = I2C(0, sda=Pin(0), scl=Pin(1), freq=400000)&#xA;lcd = I2cLcd(i2c, I2C_ADDR, I2C_NUM_ROWS, I2C_NUM_COLS)&#xA;def read_temp():&#xA;    sensor_temp = ADC(4)&#xA;    conversion_factor = 3.3 / (65535)&#xA;    reading = sensor_temp.read_u16() * conversion_factor &#xA;    temperature = 27 - (reading - 0.706)/0.001721&#xA;    formatted_temperature = &amp;#34;{:.2f}&amp;#34;.format(temperature)&#xA;    string_temperature = str(&amp;#34;Temp:&amp;#34; &amp;#43; formatted_temperature)&#xA;    print(string_temperature)&#xA;    utime.sleep(2)&#xA;    return string_temperature&#xA;while True:&#xA;    temperature = read_temp()&#xA;    lcd.move_to(0,0)&#xA;    lcd.putstr(temperature)&lt;/div&gt;&#xA;    &#xA;    &lt;div&#xA;      class=&#34;collapse-overlay to-card/90 pointer-events-none absolute inset-0 bg-linear-to-b from-transparent via-transparent opacity-0 transition-opacity duration-300&#34;&#xA;      hidden&#xA;    &gt;&#xA;      &lt;button&#xA;        class=&#34;collapse-overlay-btn text-muted-foreground bg-card/80 border-border/50 hover:bg-primary/10 hover:text-primary hover:border-primary/30 absolute bottom-4 left-1/2 flex -translate-x-1/2 items-center justify-center rounded-full border p-2 backdrop-blur-sm transition-all duration-200&#34;&#xA;        type=&#34;button&#34;&#xA;        data-code-action=&#34;expand&#34;&#xA;        aria-label=&#34;展開&#34;&#xA;        title=&#34;展開&#34;&#xA;      &gt;&#xA;        &lt;svg class=&#34;h-4 w-4&#34; fill=&#34;none&#34; stroke=&#34;currentColor&#34; viewBox=&#34;0 0 24 24&#34; xmlns=&#34;http://www.w3.org/2000/svg&#34;&gt;&#xA;  &lt;path stroke-linecap=&#34;round&#34; stroke-linejoin=&#34;round&#34; stroke-width=&#34;2&#34; d=&#34;M19 9l-7 7-7-7&#34; /&gt;&#xA;&lt;/svg&gt;&#xA;      &lt;/button&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&lt;ol start=&#34;4&#34;&gt;&#xA;&lt;li&gt;使用 VSCode 搭配 Pico 開發 MicroPython 程式&#xA;&#xA;&lt;figure&#xA;  class=&#34;image-figure not-prose my-8&#34;&#xA;  data-lightbox-enabled=&#34;&#xA;    true&#xA;  &#34;&#xA;  data-gallery-type=&#34;auto&#34;&#xA;  data-image-width=&#34;0&#34;&#xA;  data-image-height=&#34;0&#34;&#xA;  data-image-src=&#34;https://i.imgur.com/8RmvIhI.png&#34;&#xA;&gt;&#xA;  &lt;div class=&#34;image-container&#34;&gt;&#xA;    &lt;img&#xA;    src=&#34;https://i.imgur.com/8RmvIhI.png&#34;&#xA;    alt=&#34;&#34;&#xA;    &#xA;    &#xA;    loading=&#34;lazy&#34;&#xA;    decoding=&#34;async&#34;&#xA;    data-gallery-src=&#34;https://i.imgur.com/8RmvIhI.png&#34;&#xA;    data-gallery-alt=&#34;&#34;&#xA;    data-gallery-title=&#34;&#34;&#xA;  /&gt;&lt;/div&gt;&#xA;&#xA;  &lt;/figure&gt;&#xA;&lt;/li&gt;&#xA;&lt;/ol&gt;&#xA;&lt;p&gt;&#xA;&lt;figure&#xA;  class=&#34;image-figure not-prose my-8&#34;&#xA;  data-lightbox-enabled=&#34;&#xA;    true&#xA;  &#34;&#xA;  data-gallery-type=&#34;auto&#34;&#xA;  data-image-width=&#34;0&#34;&#xA;  data-image-height=&#34;0&#34;&#xA;  data-image-src=&#34;https://i.imgur.com/ez2V7OS.jpg&#34;&#xA;&gt;&#xA;  &lt;div class=&#34;image-container&#34;&gt;&#xA;    &lt;img&#xA;    src=&#34;https://i.imgur.com/ez2V7OS.jpg&#34;&#xA;    alt